# OpenWA API — Development Dockerfile (hot reload via nest start --watch)
FROM node:22-slim

WORKDIR /app

# Install build dependencies + Chromium for Puppeteer
RUN apt-get update && apt-get install -y \
    python3 \
    make \
    g++ \
    chromium \
    fonts-liberation \
    libappindicator3-1 \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xdg-utils \
    dumb-init \
    && rm -rf /var/lib/apt/lists/*

ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# Install dependencies (cached layer — only rebuilt when package.json changes)
COPY package*.json ./
RUN npm ci

# Source code is mounted as a volume at runtime — no COPY needed here
# The nest start --watch command will watch /app/src for changes

EXPOSE 2785

ENTRYPOINT ["dumb-init", "--"]
CMD ["npm", "run", "start:dev"]
