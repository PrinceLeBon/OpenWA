# OpenWA Dashboard — Development Dockerfile (Vite HMR)
FROM node:20-alpine

WORKDIR /app

# Install dependencies (cached layer — only rebuilt when package.json changes)
COPY package*.json ./
RUN npm ci

# Source code is mounted as a volume at runtime — no COPY needed here
# Vite will watch /app/src for changes and push HMR updates to the browser

EXPOSE 2886

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
